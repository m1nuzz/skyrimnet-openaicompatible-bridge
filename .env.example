HOST=127.0.0.1
PORT=4000

# Universal API Key (will be used if provider-specific key is missing)
API_KEY=

# Optional provider-specific keys
MISTRAL_API_KEY=
GEMINI_API_KEY=

# alias used when model not specified
DEFAULT_MODEL_ALIAS=mistral-large

# alias -> provider:model
# provider: mistral | gemini
MODEL_MAP={"mistral-large":"mistral:mistral-large-latest","gemini-1.5-pro":"gemini:gemini-1.5-pro"}
