# SkyrimNet Provider Bridge - Environment Configuration
# Copy this file to .env and fill in the values for your setup.

# Server Configuration
HOST=127.0.0.1
PORT=4000

# API Configuration
# Your API key for the target service (if required)
API_KEY=

# Base URL for the OpenAI-compatible API endpoint
# Example values:
BASE_URL=http://localhost:11434/v1

# Known OpenAI-compatible endpoints (uncomment and use as needed):
# BASE_URL=https://api.openai.com/v1
# BASE_URL=https://openrouter.ai/api/v1
# BASE_URL=https://api.groq.com/openai/v1
# BASE_URL=https://api.together.xyz/v1
# BASE_URL=https://api.deepseek.com/v1
# BASE_URL=https://api.mistral.ai/v1
# BASE_URL=http://localhost:11434/v1  # Ollama, LM Studio, etc.

# Notes:
# - Only BASE_URL and API_KEY are required for the simplified bridge.
# - The model name from the request will be passed directly to the BASE_URL.
# - Ensure the BASE_URL points to an OpenAI-compatible API endpoint.