# SkyrimNet Provider Bridge - Environment Configuration
# Copy this file to .env and fill in the values for your setup.

# ---- Server bind ----
HOST=127.0.0.1
PORT=4000

# ---- API key ----
# Preferred: provider-specific key. GEMINI_API_KEY takes priority over API_KEY.
GEMINI_API_KEY=
# Universal token. Sent as `Authorization: Bearer <API_KEY>` to upstream.
API_KEY=

# ---- Upstream URL ----
# CUSTOM_BASE_URL takes priority over BASE_URL.
# Either must point at an OpenAI-compatible /chat/completions root (no
# trailing /chat/completions — the bridge appends it).
CUSTOM_BASE_URL=
# BASE_URL fallback. Default in code is Gemini's OpenAI-compat endpoint.
BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# ---- Other known OpenAI-compatible endpoints ----
# BASE_URL=https://api.openai.com/v1
# BASE_URL=https://openrouter.ai/api/v1
# BASE_URL=https://api.groq.com/openai/v1
# BASE_URL=https://api.together.xyz/v1
# BASE_URL=https://api.deepseek.com/v1
# BASE_URL=https://api.mistral.ai/v1
# BASE_URL=http://localhost:11434/v1     # Ollama
# BASE_URL=http://localhost:1234/v1      # LM Studio

# Notes:
# - The model name from the request is forwarded as-is to the upstream;
#   the bridge does NOT rewrite/alias model names.
# - For Gemini's OpenAI-compat endpoint the key is *also* appended as ?key=...
#   (Gemini ignores Authorization for some routes). For any other upstream
#   the bridge sends only the Authorization header.
